# Deedify Combined Environment Configuration
# Copy this file to .env and configure your values

# =============================================================================
# BACKEND API CONFIGURATION (apps/api/.env)
# =============================================================================

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/deedify

# Supabase Configuration (Optional)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE=your_supabase_service_role_key

# Solana Configuration
SOLANA_CLUSTER=devnet
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=11d1056e-2fdc-43bc-a985-c649236d3af1
ANCHOR_PROVIDER_URL=https://devnet.helius-rpc.com/?api-key=11d1056e-2fdc-43bc-a985-c649236d3af1
MINT_AUTH_SECRET=your_ed25519_private_key_base58
METAPLEX_AUTHORITY=your_authority_public_key
ORCHESTRATOR_PROGRAM_ID=your_orchestrator_program_id
ESCROW_PROGRAM_ID=your_escrow_program_id

# Application Configuration
JWT_SECRET=your_jwt_secret_change_me
PORT=4000
REDIS_URL=redis://localhost:6379
NODE_ENV=development
USE_MOCK_ESCROW=true

# Optional Services
KYC_PROVIDER=veriff
KYC_API_KEY=your_veriff_api_key
STRIPE_SECRET_KEY=sk_test_your_stripe_key
MAPBOX_TOKEN=your_mapbox_token

# Valuation Service
VALUATION_SERVICE_URL=http://localhost:3001

# =============================================================================
# FRONTEND CONFIGURATION (frontend/.env.local)
# =============================================================================

# API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Supabase Configuration (Optional)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Solana Configuration
NEXT_PUBLIC_SOLANA_RPC=https://devnet.helius-rpc.com/?api-key=11d1056e-2fdc-43bc-a985-c649236d3af1
NEXT_PUBLIC_ORCHESTRATOR_PROGRAM_ID=your_orchestrator_program_id

# =============================================================================
# DEVELOPMENT NOTES
# =============================================================================

# 1. Copy apps/api/.env.example to apps/api/.env
# 2. Copy frontend/.env.example to frontend/.env.local
# 3. Update the values above with your actual configuration
# 4. For development, the default values should work for most cases
# 5. Make sure to change JWT_SECRET to a secure random string
# 6. Update API keys with your actual Helius, Supabase, etc. keys